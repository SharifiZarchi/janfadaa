        const verificationCode = $($formDiv + " input[name=verificationCode]").val();
        if (verificationCode == "") {
            setToastAlert(" کد پیامک شده را وارد کنید", "danger");
            return;
        }


        startLoading();

        const data = {
            action: 'verificationSms',
            verificationCode: verificationCode,
            mobile: mobile,
            fullname: fullname,
            state: state,
            city: city,
            birthday: birthday,
            gender: gender,
            education: education,
            description: description,
            formToken: formToken,
        }
        $.ajax({
            url: extraJs.ajaxUrl,
            method: 'POST',
            data: data,
            dataType: 'json',
            success: function (result) {

                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById('verifySmsModal')).hide();
                    setToastAlert(result.data, "success");

                    setTimeout(function () {
                        location.reload(true);
                        return;
                    }, 2000);

                    createdFormToken();


                } else {
                    setToastAlert(result.data.message, "danger");
                }

                endLoading();

            },
            error: function () {
                setToastAlert("دوباره تلاش کنید", "danger")
                location.reload(true);
                return;

            }
        });

    });

    $('body').on('hidden.bs.modal', '#verifySmsModal', function () {
