// let timerSms = 0;

function startLoading() {
    var overlay = document.getElementById("overlay");

    if (overlay) {
        overlay.style.display = "flex";
        overlay.style.opacity = "0";
        overlay.style.transition = "opacity 0.5s ease-in-out";

        setTimeout(() => {
            overlay.style.opacity = "1";
        }, 10);
    }

    document.body.classList.add("no-scroll");
}

function endLoading() {

    var overlay = document.getElementById("overlay");

    if (overlay) {
        overlay.style.transition = "opacity 0.5s ease-in-out";
        overlay.style.opacity = "0";

        setTimeout(() => {
            overlay.style.display = "none";
        }, 500);
    }

    document.body.classList.remove("no-scroll");

}

function incrementCounter() {
    const counterElement = document.querySelector('.counter-number');
    let currentNumber = parseInt(counterElement.getAttribute('data-target'));
    currentNumber += 1;
    counterElement.setAttribute('data-target', currentNumber);
    counterElement.textContent = currentNumber.toLocaleString('en-US');
}

const counterNumber = document.querySelectorAll('.counter-number');
if (counterNumber) {
    function startCounter(element) {
        const target = parseInt(element.getAttribute('data-target'));
        const duration = 2000;
        const step = Math.ceil(target / (duration / 16));
        let current = 0;

        const timer = setInterval(() => {
            current += step;
            if (current >= target) {
                current = target;
                clearInterval(timer);
            }
            element.textContent = current.toLocaleString();
        }, 16);
    }

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                startCounter(entry.target);
                observer.unobserve(entry.target);
            }
        });
    }, {
        threshold: 0.5
    });


    counterNumber.forEach(counter => {
        observer.observe(counter);
    });

}

document.querySelectorAll('.goto-btn').forEach(item => {
    item.addEventListener('click', function () {
        const dataBlock = this.getAttribute('data-goto');
        const mapSection = document.getElementById(dataBlock);
        mapSection.scrollIntoView({
            behavior: 'smooth'
        });
    });
});

document.querySelectorAll('a[href^="#"]').forEach(item => {
    item.addEventListener('click', function (event) {
        event.preventDefault();

        const targetId = this.getAttribute('href').substring(1);
        const targetElement = document.getElementById(targetId);

        if (targetElement) {
            targetElement.scrollIntoView({
                behavior: 'smooth'
            });
        }
    });
});

function setToastAlert(message, type = 'info') {
    const toastElement = document.getElementById('taiToast');
    const toastBody = toastElement.querySelector('.toast-body');

    const typeClasses = {
        'success': 'text-bg-success',
        'danger': 'text-bg-danger',
        'warning': 'text-bg-warning',
        'info': 'text-bg-info',
        'primary': 'text-bg-primary'
    };

    Object.values(typeClasses).forEach(cls => {
        toastElement.classList.remove(cls);
    });

    const bgClass = typeClasses[type];
    toastElement.classList.add(bgClass);

    toastBody.innerHTML = message;

    const toastBootstrap = bootstrap.Toast.getOrCreateInstance(toastElement);
    toastBootstrap.show();
}


let interval = null;

function startTimer() {

    if (interval) {
        clearInterval(interval);
    }

    let timer = extraJs.sms_timer * 60;

    interval = setInterval(() => {

        const minutes = String(Math.floor(timer / 60)).padStart(2, '0');
        const seconds = String(timer % 60).padStart(2, '0');

        document.getElementById('timer').textContent = `${minutes}:${seconds}`;

        if (timer <= 0) {
            clearInterval(interval);
            document.getElementById('resendCode').disabled = false;
            return;
        }

        timer--;

    }, 1000);
}

document.getElementById('resendCode').addEventListener('click', function () {
    sendSms();

});

function validateMobile(mobile) {
    let regex = /^09\d{9}$/;
    return regex.test(mobile);
}
let isSendSms = true;
let formToken = "";
let mobile = "";


function sendSms() {
    startTimer();
    document.getElementById('resendCode').disabled = true;

    if (isSendSms && formToken != "") {

        let captcha = document.getElementById('captcha').value;
        let captchaData = document.getElementById('captchaData').value;

        const xhr = new XMLHttpRequest();
        xhr.open('POST', extraJs.ajaxUrl, true);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.onload = function () {

            const response = JSON.parse(xhr.responseText);


            if (xhr.status !== 200) {
                if (response.data.error != undefined && response.data.error == "reload") {
                    location.reload(true);
                    return;
                }
            }

        };
        xhr.send(`action=sendSms&mobileNumber=${mobile}&captcha=${captcha}&captchaData=${captchaData}&formToken=${formToken}`);

    }
}

function checkForm() {
    startLoading();
    document.getElementById('verificationCodeForm').reset();


    formToken = document.getElementById('formToken').value;
    mobile = document.getElementById('mobile').value;
    let captcha = document.getElementById('captcha').value;
    let captchaData = document.getElementById('captchaData').value;

    if (formToken == "") {
        location.reload(true);
        return;
    }


    if (validateMobile(mobile)) {

        const xhr = new XMLHttpRequest();
        xhr.open('POST', extraJs.ajaxUrl, true);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.onload = function () {

            const response = JSON.parse(xhr.responseText);

            endLoading();
            if (xhr.status === 200 && response.success) {
                document.getElementById('resendCode').disabled = true;

                let otpInput = document.getElementById('verificationCode');
                otpInput.focus();

                isSendSms = response.data.success

                setToastAlert('پیام با موفقیت ارسال شد', 'success');
                new bootstrap.Modal(document.getElementById('verifySmsModal')).show();

                sendSms();

            } else {

                let textMassage = response.data.massage;

                if (textMassage == undefined) {
                    textMassage = response.data
                }


                setToastAlert(textMassage, "danger");

                if (response.data.error != undefined && response.data.error == "reload") {
                    location.reload(true);
                    return;
                }
            }

        };

        xhr.send(`action=checkForm&captcha=${captcha}&mobileNumber=${mobile}&captchaData=${captchaData}&formToken=${formToken}`);

    } else {
        endLoading();
        setToastAlert('شماره موبایل نامعتبر است', "danger");
    }
}


let captchaImage = document.getElementById('captchaImage');

function createdFormToken() {
    startLoading();

    let formTokenInput = document.getElementById('formToken');
    let captchaImage = document.getElementById('captchaImage');
    let captchaInput = document.getElementById('captcha');
    let captchaData = document.getElementById('captchaData');


    formToken = formTokenInput.value

    if (formToken == "") {
        location.reload(true);
        return;
    }

    const xhr = new XMLHttpRequest();
    xhr.open('POST', extraJs.ajaxUrl, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function () {

        const response = JSON.parse(xhr.responseText);

        if (xhr.status === 200 && response.success) {
            document.getElementById('requestForm').reset();

            let resData = response.data

            formTokenInput.value = resData.formToken;

            captchaData.value = resData.captcha.key;
            captchaInput.value = resData.captcha.word;
            captchaImage.src = resData.captcha.url;

        } else {

            let textMassage = response.data.massage;

            if (textMassage == undefined) {
                textMassage = response.data
            }

            setToastAlert(textMassage, "danger");

            if (response.data.error != undefined && response.data.error == "reload") {
                location.reload(true);
                return;
            }
        }


        endLoading();

    };

    xhr.send(`action=createdFormToken&formToken=${formToken}`);
}



const commentList = document.getElementById("commentList");
if (commentList) {

    let nextPointer = 10;
    const moreSendMedia = document.getElementById("more_send_media");

    function renderItems(data) {

        data.forEach(item => {

            const commentCard = document.createElement('div');
            commentCard.className = 'd-flex flex-column bg-white rounded-3 p-12 fw-bold f-14';

            commentCard.innerHTML = `
                    <div class="d-flex flex-row justify-content-between align-items-center border-1 border-bottom pb-12 mb-12 text-black-50">
                    <span>
                        ${item.fullname.trim()}
                    </span>
                    <div class="d-flex flex-row justify-content-end align-items-center gap-1">
                        <span class="" dir="ltr">
                        ${item.date}
                        </span>                        
                        <svg style="height: 24px; width: 24px;">
                            <use href="#calendar"></use>
                        </svg>
                    </div>
                    </div>
                    <p class="text-justify text-pre-wrap">${item.description}</p>
                `;

            commentList.appendChild(commentCard);
        });

    }

    function loadMore() {

        if (nextPointer == 0) return;
        startLoading();

        const xhr = new XMLHttpRequest();
        xhr.open("POST", extraJs.ajaxUrl, true);
        xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");

        xhr.onload = () => {
            if (xhr.status !== 200) {
                setToastAlert('لطفا چند دقیقه دیگر تلاش کنید', "danger");
                return;
            }
            try {
                const res = JSON.parse(xhr.responseText);

                if (!res.success) throw new Error();

                nextPointer = res.data.next;

                renderItems(res.data.all);

                if (nextPointer == 0) {
                    moreSendMedia.classList.add("d-none");
                } else {
                    moreSendMedia.classList.remove("d-none");
                }
            } catch {
                setToastAlert('لطفا چند دقیقه دیگر تلاش کنید', "danger");
            }

            endLoading();

        };

        xhr.send(`action=getComments&pointer=${nextPointer}`);
    }

    loadMore();

    moreSendMedia.addEventListener("click", loadMore);

}


if ('OTPCredential' in window) {
    const verifyCodeButton = document.getElementById('verifyCode');

    const inputVerificationCode = document.getElementById('verificationCode');

    if (inputVerificationCode) {

        const ac = new AbortController();

        navigator.credentials
            .get({
                otp: {
                    transport: ['sms'],
                },
                signal: ac.signal,
            })
            .then((otp) => {

                if (otp && otp.code) {
                    inputVerificationCode.value = otp.code;

                    verifyCodeButton.click();

                    verifyLogin(otp.code);


                } else { }

                ac.abort();
            })
            .catch((err) => {

                if (ac.signal.aborted === false) {
                    ac.abort();
                }
            });
    }
}

