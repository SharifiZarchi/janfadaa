        //     setToastAlert("شهر خود را وارد کنید", "danger");
        //     return;
        // }

        birthday = $($formDiv + " input[name=birthday]").val();

        if (birthday && birthday.trim() !== "") {
            var pattern = /^\d{4}\/\d{2}\/\d{2}$/;

            if (!pattern.test(birthday)) {
                setToastAlert("فرمت تاریخ تولد باید به صورت 1405/01/03 باشد", "danger");
                return;
            }

            var parts = birthday.split('/');
            var year = parseInt(parts[0]);
            var month = parseInt(parts[1]);
            var day = parseInt(parts[2]);


            if (year.length !== 4) {
                setToastAlert("سال رو به درستی وارد کنید", "danger");
                return;
            }

            if (month < 1 || month > 12) {
                setToastAlert("ماه باید بین 01 تا 12 باشد", "danger");
                return;
            }

            if (month < 1 || month > 12) {
                setToastAlert("ماه باید بین 01 تا 12 باشد", "danger");
                return;
            }

            if (day < 1 || day > 31) {
                setToastAlert("روز باید بین 01 تا 31 باشد", "danger");
                return;
            }

            var daysInMonth = [31, 31, 31, 31, 31, 31, 30, 30, 30, 30, 30, 29];
            if (day > daysInMonth[month - 1]) {
                setToastAlert("روز وارد شده برای این ماه معتبر نیست", "danger");
                return;
            }
        }

        // if (birthday == "") {
        //     setToastAlert("تاریخ تولد را وارد کنید", "danger");
