        // if (description == "") {
        //     setToastAlert(" توضیحات را وارد کنید", "danger");
        //     return;
        // }

        const captcha = $($formDiv + " input[name=captcha]").val();
        if (captcha == "") {
            setToastAlert("کد  کد امنیتی را وارد کنید", "danger");
            return;
        }

        checkForm();


        //  this.submit();

    });

    $('form#verificationCodeForm').submit(function (e) {
